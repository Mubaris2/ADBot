# ── Twilio ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Gemini ────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Pollinations (for background music) ──────────────────
POLLINATIONS_API_KEY=your_pollinations_api_key_here

# ── Cloudinary ────────────────────────────────────────────
# Found in Cloudinary dashboard -> Settings -> Upload presets
CLOUDINARY_BASE_URL=https://api.cloudinary.com/v1_1/your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_upload_preset_name

# Modal (set this after running: modal deploy modal_processor.py)
MODAL_ENDPOINT_URL=https://your-workspace--your-app.modal.run
